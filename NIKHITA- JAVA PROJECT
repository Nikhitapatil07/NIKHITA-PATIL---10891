import java.util.Scanner;

// Movie Class
class Movie {

    String movieName;
    String showTime;

    Movie(String movieName, String showTime) {
        this.movieName = movieName;
        this.showTime = showTime;
    }

    void displayMovie() {
        System.out.println("Movie Name: " + movieName);
        System.out.println("Show Time: " + showTime);
    }
}


// Seat Class
class Seat {

    String type;
    double price;
    boolean isBooked;

    Seat(String type, double price) {

        this.type = type;
        this.price = price;
        isBooked = false;
    }
}


// Booking Class
class Booking {

    Seat[][] seats;
    double totalCost = 0;

    Booking(int rows, int cols) {

        seats = new Seat[rows][cols];

        for(int i=0;i<rows;i++) {

            for(int j=0;j<cols;j++) {

                if(i==0)
                    seats[i][j] =
                    new Seat("Premium",300);

                else
                    seats[i][j] =
                    new Seat("Regular",200);
            }
        }
    }


    // Display seats
    void displaySeats() {

        System.out.println("\nSeat Layout");

        for(int i=0;i<seats.length;i++) {

            for(int j=0;j<seats[i].length;j++) {

                if(seats[i][j].isBooked)
                    System.out.print(" X ");

                else
                    System.out.print(" O ");
            }

            System.out.println();
        }
    }



    // Book seat
    void bookSeat(int row,int col) {

        if(row>=seats.length ||
           col>=seats[0].length ||
           row<0 || col<0)
        {
            System.out.println(
            "Invalid seat");

            return;
        }


        if(seats[row][col].isBooked) {

            System.out.println(
            "Seat already booked");
        }

        else {

            seats[row][col].isBooked=true;

            totalCost =
            totalCost +
            seats[row][col].price;

            System.out.println(
            "Seat booked successfully");
        }
    }



    void confirmation() {

        System.out.println(
        "\nBooking Confirmed");

        System.out.println(
        "Total Cost = ₹"
        + totalCost);
    }

}



// Main Class
public class Main {

    public static void main(String[] args) {

        Scanner sc =
        new Scanner(System.in);


        Movie movie =
        new Movie(
        "Avengers Endgame",
        "7:00 PM");

        movie.displayMovie();


        Booking booking =
        new Booking(3,4);


        booking.displaySeats();


        System.out.println(
        "\nEnter number of seats:");

        int n =
        sc.nextInt();


        for(int i=0;i<n;i++) {

            System.out.println(
            "\nEnter Row:");

            int row =
            sc.nextInt();

            System.out.println(
            "Enter Column:");

            int col =
            sc.nextInt();

            booking.bookSeat(
            row,col);
        }


        booking.displaySeats();

        booking.confirmation();

    }
}
